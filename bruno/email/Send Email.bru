meta {
  name: Send Email
  type: http
  seq: 1
}

post {
  url: {{base_url}}/api/v1/emails/send
  body: json
  auth: none
}

body:json {
  {
    "recipients": ["user@example.com"],
    "subject": "Hello from Bruno",
    "template_name": "welcome_email",
    "variables": {
      "name": "User"
    }
  }
}
