meta {
  name: Send Email
  type: http
  seq: 1
}

post {
  url: {{base_url}}/api/v1/emails/send
  body: json
  auth: none
}

body:json {
  {
    "recipients": ["dasun.wickr@gmail.com"],
    "subject": "Hello from Bruno",
    "template_name": "welcome_email",
    "variables": {
      "name": "User"
    }
  }
}

vars:pre-request {
  base_url: http://localhost:8082
}

vars:post-response {
  email_id: res.body.id
}
