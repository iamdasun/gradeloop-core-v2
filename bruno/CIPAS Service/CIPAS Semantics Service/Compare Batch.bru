meta {
  name: Compare Batch
  type: http
  seq: 3
}

post {
  url: {{CIPAS_SEMANTICS_URL_V1}}/detect/batch
  body: json
  auth: inherit
}

body:json {
  {
    "pairs": [
      ["int sum(int a, int b) { return a + b; }", "int add(int x, int y) { int result = x + y; return result; }"],
      ["void printHello() { System.out.println(\"Hello\"); }", "void sayHi() { String msg = \"Hello\"; System.out.print(msg); }"]
    ]
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
