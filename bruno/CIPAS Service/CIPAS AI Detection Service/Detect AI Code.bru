meta {
  name: Detect AI Code
  type: http
  seq: 3
}

post {
  url: {{CIPAS_AI_URL_V1}}/detect
  body: json
  auth: inherit
}

body:json {
  {
    "code": "def fibonacci(n):\n    if n <= 1:\n        return n\n    return fibonacci(n-1) + fibonacci(n-2)"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
