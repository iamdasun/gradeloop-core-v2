meta {
  name: Send Email
  type: http
  seq: 1
}

post {
  url: {{gateway_url}}/api/v1/emails/send
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "recipients": ["dasun.wickr@gmail.com"],
    "subject": "Hello from Bruno",
    "template_name": "welcome_email",
    "variables": {
      "name": "User"
    }
  }
}

vars:pre-request {
  gateway_url: http://localhost:8080
}
