meta {
  name: Change Password
  type: http
  seq: 7
}

post {
  url: {{AUTH_URL_V1}}/change-password
  body: json
  auth: bearer
}

auth:bearer {
  token: {{ACCESS_TOKEN}}
}

body:json {
  {
    "current_password": "Strong#Pass123!",
    "new_password": "Admin@1234"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
