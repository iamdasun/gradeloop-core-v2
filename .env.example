# =============================================================================
# Gradeloop Core v2 - Environment Configuration
# =============================================================================
# Copy this file to .env and update values for your environment
# NEVER commit .env file to version control
# =============================================================================

# =============================================================================
# Service Ports Configuration
# =============================================================================
IAM_SVC_PORT=8081
EMAIL_SVC_PORT=8082

# =============================================================================
# Database Cluster Configuration (Aiven PostgreSQL)
# =============================================================================
GRA_DB_HOST=gradeloop-gradeloop-project-v2.k.aivencloud.com
GRA_DB_USER=avnadmin
GRA_DB_PORT=17317
GRA_DB_PASSWORD=your-database-password
GRA_DB_SSLMODE=require

# Service-specific database names
IAM_SVC_DB_NAME=iam-db
EMAIL_SVC_DB_NAME=email-db

# =============================================================================
# IAM Service Configuration
# =============================================================================
IAM_SVC_ENABLE_PREFORK=true

# =============================================================================
# Frontend Configuration
# =============================================================================
# Update this to your production frontend URL
FRONTEND_URL=http://localhost:3000

# =============================================================================
# SMTP Email Configuration
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_PORT=587

# =============================================================================
# Super Admin Seed Configuration (Initial Setup)
# =============================================================================
# IMPORTANT: Change these credentials in production!
# Password must be strong (min 12 chars, uppercase, lowercase, number, special)
SUPER_ADMIN_USERNAME=superadmin@gradeloop.com
SUPER_ADMIN_PASSWORD=YourSecurePassword123!

# =============================================================================
# JWT Configuration
# =============================================================================
# CRITICAL: Change this to a strong random secret in production (min 32 chars)
# Generate with: openssl rand -base64 32
JWT_SECRET_KEY=your-super-secret-jwt-key-min-32-chars-change-in-production

# Token expiry in minutes
JWT_ACCESS_TOKEN_EXPIRY=15
JWT_REFRESH_TOKEN_EXPIRY=10080

# =============================================================================
# Kong Gateway Configuration (Optional overrides)
# =============================================================================
# KONG_PROXY_LISTEN=0.0.0.0:8000
# KONG_ADMIN_LISTEN=0.0.0.0:8001
# KONG_LOG_LEVEL=info

# =============================================================================
# Environment Mode
# =============================================================================
# Options: development, staging, production
APP_ENV=development
