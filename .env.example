# =============================================================================
# Gradeloop Core v2 - Environment Configuration
# =============================================================================
# Copy this file to .env and update values for your environment
# NEVER commit .env file to version control
# =============================================================================

# =============================================================================
# Service Ports Configuration
# =============================================================================
IAM_SVC_PORT=8081
EMAIL_SVC_PORT=8082

# =============================================================================
# Database Cluster Configuration (Aiven PostgreSQL)
# =============================================================================
GRA_DB_HOST=gradeloop-gradeloop-project-v2.k.aivencloud.com
GRA_DB_USER=avnadmin
GRA_DB_PORT=17317
GRA_DB_PASSWORD=your-database-password
GRA_DB_SSLMODE=require

# Service-specific database names
IAM_SVC_DB_NAME=iam-db
EMAIL_SVC_DB_NAME=email-db
KEYSTROKE_SVC_DB_NAME=keystroke-db

# =============================================================================
# IAM Service Configuration
# =============================================================================
IAM_SVC_ENABLE_PREFORK=true

# =============================================================================
# Keystroke Service Configuration
# =============================================================================
# Google Gemini API key for behavioral analysis
GEMINI_API_KEY=your_gemini_api_key_here

# MinIO Configuration
# =============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# =============================================================================
# Frontend Configuration
# =============================================================================
# Update this to your production frontend URL
FRONTEND_URL=http://localhost:3001

# =============================================================================
# SMTP Email Configuration
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_PORT=587

# =============================================================================
# Super Admin Seed Configuration (Initial Setup)
# =============================================================================
# IMPORTANT: Change these credentials in production!
# Password must be strong (min 12 chars, uppercase, lowercase, number, special)
SUPER_ADMIN_USERNAME=superadmin@gradeloop.com
SUPER_ADMIN_PASSWORD=YourSecurePassword123!

# =============================================================================
# JWT Configuration
# =============================================================================
# CRITICAL: Change this to a strong random secret in production (min 32 chars)
# Generate with: openssl rand -base64 32
JWT_SECRET_KEY=your-super-secret-jwt-key-min-32-chars-change-in-production

# Token expiry in minutes
JWT_ACCESS_TOKEN_EXPIRY=15
JWT_REFRESH_TOKEN_EXPIRY=10080

# =============================================================================
# Kong Gateway Configuration (Optional overrides)
# =============================================================================
# KONG_PROXY_LISTEN=0.0.0.0:8000
# KONG_ADMIN_LISTEN=0.0.0.0:8001
# KONG_LOG_LEVEL=info

# =============================================================================
# Environment Mode
# =============================================================================
# Options: development, staging, production
APP_ENV=development
# =============================================================================
# ACAFS Service — LLM & Execution Engine
# =============================================================================
# Gemini (rubric grading — all criteria evaluated via Gemini 2.5 Flash)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenRouter / Arcee Trinity Large (Socratic chat tutor)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=arcee-ai/trinity-large-preview:free
OPENROUTER_REASONER_MODEL=qwen/qwen3-vl-235b-a22b-thinking
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Judge0 (deterministic test-case execution)
# Use the shared Judge0 container URL defined in docker-compose
JUDGE0_URL=http://judge0:2358
# JUDGE0_API_KEY=   # Leave blank if Judge0 is running without auth

# ACAFS service tuning
ACAFS_SERVICE_NAME=acafs-service
ACAFS_SERVICE_PORT=8086
ACAFS_LOG_LEVEL=INFO
ACAFS_AST_MAX_LINES=5000
ACAFS_AST_TIMEOUT_SECONDS=2
ACAFS_RABBITMQ_EXCHANGE=submissions
ACAFS_RABBITMQ_QUEUE=acafs.evaluation
ACAFS_RABBITMQ_ROUTING_KEY=submission.created
ACAFS_RABBITMQ_CONCURRENCY=4

# =============================================================================
# CIPAS AI Detection Service Configuration
# =============================================================================
CIPAS_AI_SVC_PORT=8087
CIPAS_AI_HOST=0.0.0.0
CIPAS_AI_DEVICE=cpu
