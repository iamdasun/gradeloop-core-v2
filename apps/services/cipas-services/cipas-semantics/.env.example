# Semantic Clone Detection API Configuration
# Copy this file to .env and modify as needed

# API Server Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# Device Configuration
# Set to 'cuda' for GPU acceleration, 'cpu' for CPU-only
DEVICE=cuda
USE_CUDA=true

# Mixed Precision (improves performance on modern GPUs)
USE_MIXED_PRECISION=true

# Model Configuration
# Path to model directory (relative to api/main.py)
MODEL_DIR=./model

# Clone Detection Threshold (0.0 - 1.0)
# Higher threshold = more strict clone detection
CLONE_THRESHOLD=0.5

# Logging Configuration
LOG_LEVEL=INFO
