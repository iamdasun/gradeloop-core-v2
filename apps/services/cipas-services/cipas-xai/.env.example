# Server Configuration
CIPAS_XAI_SVC_PORT=8085
LOG_LEVEL=info

# LLM Configuration
# Provider: openai, anthropic, ollama, openrouter, etc. (using OpenAI-compatible API)
LLM_PROVIDER=openrouter

# API Key for the LLM provider
LLM_API_KEY=your-openrouter-api-key-here

# Base URL for the LLM API
# OpenAI: https://api.openai.com/v1
# OpenRouter: https://openrouter.ai/api/v1
# Ollama (local): http://localhost:11434/v1
# Other providers: check their OpenAI-compatible endpoint
LLM_BASE_URL=https://openrouter.ai/api/v1

# Model to use
# OpenRouter: qwen/qwen3-vl-235b-a22b-thinking, openai/gpt-4o-mini, etc.
# Free model for testing: arcee-ai/trinity-large-preview:free
# OpenAI: gpt-4o-mini, gpt-4o, gpt-3.5-turbo
# Ollama: llama2, mistral, etc.
LLM_MODEL=arcee-ai/trinity-large-preview:free

# Extra headers for providers like OpenRouter (comma-separated key=value pairs)
# HTTP-Referer: Site URL for rankings on openrouter.ai (optional)
# X-OpenRouter-Title: Site title for rankings on openrouter.ai (optional)
LLM_EXTRA_HEADERS=HTTP-Referer=http://localhost:3000,X-OpenRouter-Title=GradeLoop CIPAS-XAI

# Maximum tokens in response
LLM_MAX_TOKENS=2048

# Temperature (0.0 - 2.0): Higher = more creative, Lower = more deterministic
LLM_TEMPERATURE=0.7

# Request timeout in seconds
LLM_TIMEOUT=60
