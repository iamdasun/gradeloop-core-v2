# Server Configuration
SERVER_PORT=8081
ENABLE_PREFORK=false

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=iam_db
DB_SSLMODE=disable

# Super Admin Seed (Required for initial setup)
# Note: Password cannot be a default value (Admin@1234, password, changeme)
SUPER_ADMIN_USERNAME=superadmin@gradeloop.com
SUPER_ADMIN_PASSWORD=YourSecurePassword123!

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-min-32-chars
JWT_ACCESS_TOKEN_EXPIRY=15
JWT_REFRESH_TOKEN_EXPIRY=7
